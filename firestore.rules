rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }

    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             request.resource.data[field] == null ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidTransaction(data) {
      return hasRequiredFields(['userId', 'type', 'amount', 'description', 'date', 'walletId', 'createdAt']) &&
             data.userId is string && data.userId.size() > 0 &&
             data.type in ['income', 'expense'] &&
             data.amount is number && data.amount > 0 &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 100 &&
             data.date is timestamp &&
             isValidOptionalString('category', 1, 50) &&
             data.walletId is string && data.walletId.size() > 0 && data.walletId.size() <= 50 &&
             data.createdAt is timestamp;
    }

    function isValidDebt(data) {
      return hasRequiredFields(['userId', 'type', 'amount', 'description', 'status', 'createdAt']) &&
             data.userId is string && data.userId.size() > 0 &&
             data.type in ['payable', 'receivable'] &&
             data.amount is number && data.amount > 0 &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 100 &&
             data.status in ['unpaid', 'paid'] &&
             data.createdAt is timestamp;
    }

    function isValidGoal(data) {
      return hasRequiredFields(['userId', 'name', 'targetAmount', 'currentAmount', 'walletId', 'createdAt']) &&
             data.userId is string && data.userId.size() > 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.targetAmount is number && data.targetAmount > 0 &&
             data.currentAmount is number && data.currentAmount >= 0 &&
             data.walletId is string && data.walletId.size() > 0 && data.walletId.size() <= 50 &&
             data.createdAt is timestamp;
    }

    function isValidWallet(data) {
      return hasRequiredFields(['userId', 'name', 'createdAt']) &&
             data.userId is string && data.userId.size() > 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 50 &&
             data.createdAt is timestamp;
    }

    function isValidCategory(data) {
      return hasRequiredFields(['userId', 'name', 'type', 'createdAt']) &&
             data.userId is string && data.userId.size() > 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 50 &&
             data.type in ['income', 'expense'] &&
             data.createdAt is timestamp;
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && isDocOwner() && isValidTransaction(request.resource.data) && uidNotModified() && areImmutableFieldsUnchanged(['createdAt']);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /debts/{debtId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidDebt(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && isDocOwner() && isValidDebt(request.resource.data) && uidNotModified() && areImmutableFieldsUnchanged(['createdAt']);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /goals/{goalId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidGoal(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && isDocOwner() && isValidGoal(request.resource.data) && uidNotModified() && areImmutableFieldsUnchanged(['createdAt']);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /wallets/{walletId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidWallet(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && isDocOwner() && isValidWallet(request.resource.data) && uidNotModified() && areImmutableFieldsUnchanged(['createdAt']);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /categories/{categoryId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidCategory(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && isDocOwner() && isValidCategory(request.resource.data) && uidNotModified() && areImmutableFieldsUnchanged(['createdAt']);
      allow delete: if isAuthenticated() && isDocOwner();
    }
  }
}
