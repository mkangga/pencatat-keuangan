{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction representing either income or expense.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "notes": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "category": { "type": "string" },
        "walletId": { "type": "string" },
        "goalId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "amount", "description", "date", "createdAt"]
    },
    "Wallet": {
      "title": "Wallet",
      "description": "A user's wallet or bank account.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "createdAt"]
    },
    "CategoryGroup": {
      "title": "Category Group",
      "description": "A group for categorizing transactions (Needs, Wants, Savings, Debts).",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "type", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "description": "A category for transactions.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "groupId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "type", "createdAt"]
    },
    "Debt": {
      "title": "Debt",
      "description": "A debt or receivable record.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["payable", "receivable"] },
        "amount": { "type": "number" },
        "expectedAmount": { "type": "number" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["unpaid", "paid"] },
        "dueDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "amount", "description", "status", "createdAt"]
    },
    "Goal": {
      "title": "Goal",
      "description": "A financial goal for the future.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "targetAmount": { "type": "number" },
        "currentAmount": { "type": "number" },
        "deadline": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "targetAmount", "currentAmount", "status", "createdAt"]
    },
    "Budget": {
      "title": "Budget",
      "description": "A monthly budget for a specific category.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "categoryId": { "type": "string" },
        "categoryName": { "type": "string" },
        "amount": { "type": "number" },
        "month": { "type": "string", "description": "Format: yyyy-MM" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "categoryId", "categoryName", "amount", "month", "createdAt"]
    },
    "Asset": {
      "title": "Asset",
      "description": "A user's investment asset (stock, crypto, gold, etc.).",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["stock", "crypto", "gold", "property", "other"] },
        "currentValue": { "type": "number" },
        "initialValue": { "type": "number" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "type", "currentValue", "initialValue", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "bottomNavTabs": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "List of tab names for the bottom navigation bar."
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["displayName", "email", "role", "createdAt"]
    }
  },
  "firestore": {
    "transactions/{transactionId}": { "schema": { "$ref": "#/entities/Transaction" }, "description": "User transactions." },
    "wallets/{walletId}": { "schema": { "$ref": "#/entities/Wallet" }, "description": "User wallets." },
    "categoryGroups/{groupId}": { "schema": { "$ref": "#/entities/CategoryGroup" }, "description": "User category groups." },
    "categories/{categoryId}": { "schema": { "$ref": "#/entities/Category" }, "description": "User categories." },
    "debts/{debtId}": { "schema": { "$ref": "#/entities/Debt" }, "description": "User debts/receivables." },
    "goals/{goalId}": { "schema": { "$ref": "#/entities/Goal" }, "description": "User financial goals." },
    "budgets/{budgetId}": { "schema": { "$ref": "#/entities/Budget" }, "description": "User monthly budgets." },
    "assets/{assetId}": { "schema": { "$ref": "#/entities/Asset" }, "description": "User investment assets." },
    "users/{userId}": { "schema": { "$ref": "#/entities/User" }, "description": "User profile data." }
  }
}
